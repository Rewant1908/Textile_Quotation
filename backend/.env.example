# ── Database (MariaDB / MySQL) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=textile_quotation

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED in production (Railway). Set this to your frontend Railway URL.
# Comma-separated for multiple origins:
# ALLOWED_ORIGIN=https://your-frontend.up.railway.app,https://custom-domain.com
ALLOWED_ORIGIN=

# ── AI Agents (Google Gemini) ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cache (Redis) — optional, falls back to no-cache if not set ────────────────
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
