# Copy this file to backend/.env and fill in your values.
# backend/.env is in .gitignore and must never be committed.

# ── Node version requirement ──────────────────────────────────────────────────
# Minimum: Node 18.0.0 (LTS)
# Recommended: Node 20 LTS (Railway default)
# Do NOT use Node 16 — ES module import.meta.url requires 18+

# ── Database (MariaDB) ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mariadb_password
DB_NAME=kt_impex

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=8h

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── AI Agents ─────────────────────────────────────────────────────────────────
# Provider: 'gemini' (default) or 'openai'
AGENT_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Only needed if AGENT_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# AGENT_MODEL=gpt-4o-mini

# ── Cache (Redis) — optional, app works without it ───────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leave blank for localhost:5173 (already whitelisted in server.js)
# In production set to your Vercel/Railway frontend URL:
# ALLOWED_ORIGIN=https://kt-impex.vercel.app
ALLOWED_ORIGIN=

# ── Frontend URL (used in password reset emails) ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate limiting (requests per minute per IP) ────────────────────────────────
# Leave blank to use defaults: global=200, agents=20, auth=10
# RATE_LIMIT_GLOBAL=200
# RATE_LIMIT_AGENTS=20
# RATE_LIMIT_AUTH=10

# ── Logging ───────────────────────────────────────────────────────────────────
# 'debug' | 'info' | 'warn' | 'error'  (default: debug in dev, info in prod)
# LOG_LEVEL=info

# ── Email (for password reset — optional until you wire the TODO in auth.js) ──
# RESEND_API_KEY=re_your_resend_key_here
